    { "min": 57, "max": 64, "layer": "v8" },
    { "min": 65, "max": 72, "layer": "v9" },
    { "min": 73, "max": 80, "layer": "v10" },
    { "min": 81, "max": 88, "layer": "v11" },
    { "min": 89, "max": 96, "layer": "v12" },

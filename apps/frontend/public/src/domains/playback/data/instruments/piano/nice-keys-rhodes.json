    "Eb3": "Ds3.mp3",
    "Gb3": "Fs3.mp3",
    "A3": "A3.mp3",
    "C4": "C4.mp3",
    "Eb4": "Ds4.mp3",
    "Gb4": "Fs4.mp3",
    "A4": "A4.mp3",
    "C5": "C5.mp3",
    "Eb5": "Ds5.mp3",
    "Gb5": "Fs5.mp3",
    "A5": "A5.mp3",
    "C6": "C6.mp3",
    "Eb6": "Ds6.mp3",
    "Gb6": "Fs6.mp3",
    "A6": "A6.mp3",

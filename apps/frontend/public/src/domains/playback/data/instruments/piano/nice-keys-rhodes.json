{
  "name": "Nice Keys Rhodes",
  "version": "1.0.0",
  "author": "BassNotion",
  "description": "Professional Rhodes electric piano with 16 velocity layers",

  "storage": {
    "baseUrl": "https://iuuplfrktnzsbzibpfjm.supabase.co/storage/v1/object/public/audio-samples",
    "localPath": "/rhodes-samples",
    "bucketPath": "Keyboards/rhodes"
  },

  "velocityRanges": [

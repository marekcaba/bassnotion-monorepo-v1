# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# API Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3000

# Logging Configuration
# Log levels: ERROR, WARN, INFO, DEBUG, TRACE
# All environments default to WARN to reduce noise
# Set to INFO or DEBUG only when actively debugging
NEXT_PUBLIC_LOG_LEVEL=WARN

# Allow noisy logs in development/production (optional)
# Set to true to enable verbose logging from high-frequency components
# By default, noisy contexts are suppressed to improve performance
NEXT_PUBLIC_ALLOW_NOISY_LOGS=false

# Audio debugging (optional)
NEXT_PUBLIC_DEBUG_AUDIO=false
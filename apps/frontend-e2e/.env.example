# Playwright E2E environment
# Copy to apps/frontend-e2e/.env (gitignored) and fill in real values.

# A permanent, email-CONFIRMED test user that already has a profile row.
# Create it once in the Supabase dashboard (Auth -> Users -> Add user,
# then mark email as confirmed). auth-flow.spec.ts signs in as this user
# to exercise the signin -> signout transition against the real backend.
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=

# Optional: override the app URL the tests run against.
# Defaults to http://localhost:3001 (local PM2 dev server).
# BASE_URL=https://your-staging-url.vercel.app

  "implementation": {
    "drummerWidget": {
      "description": "The drummer widget should load manifests to understand kit structure",
      "usage": [
        "1. Load kit manifest from drums/hydrogen-kits/mp3/{category}/{kit}/manifest.json",
        "2. Map widget pads to drum types using the mapping",
        "3. Support velocity layers if available",
        "4. Fallback to 'percussion' for unmapped sounds"
      ]
    },
    "benefits": [
      "Consistent drum type identification across all kits",
      "Easy kit switching without remapping",
      "Support for velocity layers and variations",
      "Clear documentation of kit contents",
      "Future-proof for ML-based classification"
    ]
  }

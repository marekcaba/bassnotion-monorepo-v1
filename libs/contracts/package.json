{
  "name": "@bassnotion/contracts",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./services/MusicalTimeConverter": {
      "import": "./dist/src/services/MusicalTimeConverter.js",
      "require": "./dist/src/services/MusicalTimeConverter.js",
      "types": "./dist/src/services/MusicalTimeConverter.d.ts"
    },
    "./services/ProfessionalDrumProcessor": {
      "import": "./dist/src/services/ProfessionalDrumProcessor.js",
      "require": "./dist/src/services/ProfessionalDrumProcessor.js",
      "types": "./dist/src/services/ProfessionalDrumProcessor.d.ts"
    },
    "./types/musical-time": {
      "import": "./dist/src/types/musical-time.js",
      "require": "./dist/src/types/musical-time.js",
      "types": "./dist/src/types/musical-time.d.ts"
    }
  },
  "scripts": {
    "build": "npx --package=typescript tsc",
    "typecheck": "npx --package=typescript tsc --noEmit"
  },
  "dependencies": {
    "@tonejs/midi": "^2.0.28",
    "zod": "^3.25.32"
  }
}

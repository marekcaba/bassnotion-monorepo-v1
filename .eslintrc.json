{
  "root": true,
  "ignorePatterns": [
    "**/node_modules/*",
    "**/dist/*",
    "**/coverage/*",
    "**/.nx/*",
    "**/vite.config.ts",
    "**/vitest.config.ts",
    "**/vitest.config.e2e.ts",
    "scripts/migrate-exercises-to-musical-timing.ts",
    "src/test/setup.ts",
    "**/.next/*",
    "**/build/*",
    "logs/*",
    "temp/*",
    "temp-downloads/*",
    "test-results/*",
    "apps/frontend/src/app/library/[tutorialId]/v*/*",
    "apps/frontend/src/app/test-*/*",
    "docs/CLAUDE CODE TRASH BIN/*"
  ],
  "plugins": ["@nx", "@typescript-eslint", "prettier", "react-hooks"],
  "overrides": [
    {
      "files": [
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "**/*.spec.tsx",
        "**/__tests__/**/*.ts",
        "**/__tests__/**/*.tsx"
      ],
      "extends": [
        "eslint:recommended",
        "plugin:@typescript-eslint/recommended",
        "prettier"
      ],
      "parser": "@typescript-eslint/parser",
      "parserOptions": {
        "ecmaVersion": 2022,
        "sourceType": "module"
      },
      "rules": {
        "prettier/prettier": "error",
        "@typescript-eslint/no-explicit-any": "off",
        "@typescript-eslint/no-unused-vars": [
          "error",
          {
            "argsIgnorePattern": "^_",
            "varsIgnorePattern": "^_"
          }
        ]
      }
    },
    {
      "files": ["*.ts", "*.tsx", "*.js", "*.jsx"],
      "rules": {
        "@nx/enforce-module-boundaries": [
          "error",
          {
            "enforceBuildableLibDependency": true,
            "allow": [],
            "depConstraints": [
              {
                "sourceTag": "scope:frontend",
                "onlyDependOnLibsWithTags": ["scope:shared"]
              },
              {
                "sourceTag": "scope:backend",
                "onlyDependOnLibsWithTags": ["scope:shared"]
              },
              {
                "sourceTag": "scope:shared",
                "onlyDependOnLibsWithTags": ["scope:shared"]
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["*.ts", "*.tsx"],
      "excludedFiles": [
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "**/*.spec.tsx",
        "**/__tests__/**/*.ts",
        "**/__tests__/**/*.tsx"
      ],
      "extends": [
        "eslint:recommended",
        "plugin:@typescript-eslint/recommended",
        "plugin:@nx/typescript",
        "prettier"
      ],
      "parserOptions": {
        "ecmaVersion": 2022,
        "sourceType": "module"
      },
      "rules": {
        "prettier/prettier": "error",
        "@typescript-eslint/interface-name-prefix": "off",
        "@typescript-eslint/explicit-function-return-type": "off",
        "@typescript-eslint/explicit-module-boundary-types": "off",
        "@typescript-eslint/no-explicit-any": "off",
        "@typescript-eslint/no-unused-vars": [
          "error",
          {
            "argsIgnorePattern": "^_",
            "varsIgnorePattern": "^_"
          }
        ],
        "react-hooks/rules-of-hooks": "error",
        "react-hooks/exhaustive-deps": ["warn", {
          "additionalHooks": "(useCallback|useMemo|useEffect|useLayoutEffect)"
        }],
        "no-console": "error",
        "no-restricted-syntax": [
          "error",
          {
            "selector": "CallExpression[callee.object.name='console'][callee.property.name=/^(log|error|warn|debug|info)$/]",
            "message": "Use structured logging instead of console methods. For React components, use: const { logger } = useCorrelation('ComponentName'); For services, use: const logger = createStructuredLogger('ServiceName');"
          }
        ]
      }
    },
    {
      "files": ["*.js", "*.jsx"],
      "extends": ["eslint:recommended", "plugin:@nx/javascript", "prettier"],
      "rules": {
        "prettier/prettier": "error",
        "no-console": "error",
        "no-restricted-syntax": [
          "error",
          {
            "selector": "CallExpression[callee.object.name='console'][callee.property.name=/^(log|error|warn|debug|info)$/]",
            "message": "Use structured logging instead of console methods. Use: const logger = createStructuredLogger('ServiceName');"
          }
        ]
      }
    },
    {
      "files": ["*.json"],
      "parser": "jsonc-eslint-parser",
      "rules": {
        "@nx/dependency-checks": "error"
      }
    }
  ]
}

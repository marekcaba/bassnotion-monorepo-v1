{
  "*.{js,jsx,ts,tsx}": [
    "eslint --fix --rule \"no-console: off\" --rule \"no-restricted-syntax: off\" --rule \"@typescript-eslint/no-unused-vars: off\" --rule \"@typescript-eslint/no-unused-expressions: off\"",
    "prettier --write"
  ],
  "*.{json,md,yml,yaml}": ["prettier --write"],
  "*.css": ["prettier --write"],
  "package.json": ["prettier --write"]
}
